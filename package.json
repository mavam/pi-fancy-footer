{
  "name": "pi-fancy-footer",
  "version": "1.1.0",
  "description": "A fancy footer extension for pi",
  "type": "module",
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "footer",
    "statusline"
  ],
  "author": "Matthias Vallentin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mavam/pi-fancy-footer.git"
  },
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api.ts"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "node --test --experimental-strip-types src/*.test.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
